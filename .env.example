# ─── Database ───────────────────────────────────────────────────────────────
POSTGRES_USER=redinfo
POSTGRES_PASSWORD=redinfo_dev_password
POSTGRES_DB=redinfo
DATABASE_URL=postgresql://redinfo:redinfo_dev_password@postgres:5432/redinfo

# ─── Backend ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# JWT
JWT_SECRET=change_this_to_a_random_secret_at_least_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── OAuth — Google ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Dev:  http://localhost:3000/auth/google/callback
# Prod: https://yourdomain.com/api/auth/google/callback  (via nginx)
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ─── OAuth — Microsoft ───────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_TENANT_ID=common
# Dev:  http://localhost:3000/auth/microsoft/callback
# Prod: https://yourdomain.com/api/auth/microsoft/callback  (via nginx)
MICROSOFT_CALLBACK_URL=http://localhost:3000/auth/microsoft/callback

# ─── Frontend ────────────────────────────────────────────────────────────────
# Dev (Vite dev server proxies to backend directly):
VITE_API_URL=http://localhost:3000
# Prod (nginx proxies /api/* → backend) — set as Docker build-arg instead:
# docker compose -f ... build --build-arg VITE_API_URL=/api frontend
