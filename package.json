{
  "name": "redinfo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "build": "pnpm -r build",
    "lint": "pnpm --parallel -r lint",
    "typecheck": "pnpm --parallel -r typecheck",
    "db:migrate": "pnpm --filter backend prisma:migrate",
    "db:studio": "pnpm --filter backend prisma:studio",
    "validate:env": "node scripts/validate-env.js",
    "setup:ci": "node scripts/setup-ci.js",
    "policy-check": "node scripts/validate-env.js",
    "ado:mcp": "npx -y @azure-devops/mcp jpsfs"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.32.1"
  }
}
